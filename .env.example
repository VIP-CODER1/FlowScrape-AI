# Stripe Integration
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_SMALL_PACK_PRICE_ID=price_xxxxxxxxxxxxx_small
STRIPE_MEDIUM_PACK_PRICE_ID=price_xxxxxxxxxxxxx_medium
STRIPE_LARGE_PACK_PRICE_ID=price_xxxxxxxxxxxxx_large
